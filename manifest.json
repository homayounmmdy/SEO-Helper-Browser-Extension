{
  "manifest_version": 3,
  "name": "SEO Helper",
  "version": "1.0",
  "description": "Shows page title, description, canonical, schema (data structure), and lists headings.",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "./icon.png",
      "48": "./icon.png",
      "128": "./icon.png"
    }
  },
  "icons": {
    "16": "./icon.png",
    "48": "./icon.png",
    "128": "./icon.png"
  }
}
